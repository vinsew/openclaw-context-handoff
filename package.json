{
  "name": "openclaw-context-handoff",
  "version": "1.0.3",
  "type": "module",
  "description": "OpenClaw plugin for context usage monitoring and automatic conversation handoff.",
  "license": "MIT",
  "author": "vinsew",
  "homepage": "https://github.com/vinsew/openclaw-context-handoff#readme",
  "bugs": {
    "url": "https://github.com/vinsew/openclaw-context-handoff/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinsew/openclaw-context-handoff.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "index.ts",
    "scripts/agent-install.sh",
    "openclaw.plugin.json",
    "README.md",
    "AGENT-BOOTSTRAP.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "openclaw-context-handoff",
      "localPath": "extensions/context-monitor",
      "defaultChoice": "npm"
    }
  },
  "keywords": [
    "openclaw",
    "context-handoff",
    "context-monitor",
    "plugin",
    "agentic"
  ],
  "main": "index.ts"
}
