{
  "name": "openclaw-context-handoff",
  "version": "1.0.6",
  "type": "module",
  "description": "OpenClaw plugin for context usage monitoring and handoff policy injection.",
  "license": "MIT",
  "author": "vinsew",
  "homepage": "https://github.com/vinsew/openclaw-context-handoff#readme",
  "bugs": {
    "url": "https://github.com/vinsew/openclaw-context-handoff/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinsew/openclaw-context-handoff.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "index.ts",
    "scripts/agent-install.sh",
    "openclaw.plugin.json",
    "README.md",
    "AGENT-BOOTSTRAP.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "docs/configuration.md",
    "docs/behavior.md",
    "docs/release.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "openclaw-context-handoff",
      "defaultChoice": "npm"
    }
  },
  "keywords": [
    "openclaw",
    "context-handoff",
    "context-monitor",
    "plugin",
    "agentic"
  ],
  "main": "index.ts"
}
